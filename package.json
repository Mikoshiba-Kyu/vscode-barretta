{
  "name": "vscode-barretta",
  "displayName": "Barretta",
  "description": "Assistant Extension for writing Excel VBA in VSCode.",
  "publisher": "Mikoshiba-Kyu",
  "author": {
    "name": "Mikoshiba-Kyu"
  },
  "version": "1.0.3",
  "engines": {
    "vscode": "^1.68.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "icon": "icon/icon_128x128.png",
  "license": "SEE LICENSE IN license.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mikoshiba-Kyu/vscode-barretta"
  },
  "capabilities": {
    "virtualWorkspaces": false
  },
  "activationEvents": [
    "workspaceContains:barretta-core"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n/package",
  "contributes": {
    "configuration": [
      {
        "title": "Barretta",
        "properties": {
          "barretta.hotReload": {
            "type": "boolean",
            "description": "%config.hotReload.description%",
            "default": true
          },
          "barretta.push.ignoreDocuments": {
            "type": "boolean",
            "description": "%config.pushIgnoreDocuments.description%",
            "default": true
          },
          "barretta.pull.ignoreDocuments": {
            "type": "boolean",
            "description": "%config.pullIgnoreDocuments.description%",
            "default": true
          },
          "barretta.pull.encodingToUtf8": {
            "type": "boolean",
            "description": "%config.encodingToUtf8.description%",
            "default": true
          },
          "barretta.vbaLint.enable": {
            "type": "boolean",
            "description": "%config.vbaLintEnable.description%",
            "default": true
          },
          "barretta.vbaLint.processOnSave": {
            "type": "boolean",
            "description": "%config.vbaLintProcessOnSave.description%",
            "default": false
          },
          "barretta.vbaEncoding": {
            "type": "string",
            "enum": [
              "Shift-JIS",
              "GB2312",
              "ANSI"
            ],
            "default": "Shift-JIS",
            "description": "%config.vbaEncoding.description%"
          }
        }
      }
    ],
    "commands": [
      {
        "command": "vscode-barretta.init",
        "title": "%command.init.title%"
      },
      {
        "command": "vscode-barretta.push",
        "title": "%command.push.title%"
      },
      {
        "command": "vscode-barretta.pull",
        "title": "%command.pull.title%"
      },
      {
        "command": "vscode-barretta.open",
        "title": "%command.open.title%"
      }
    ],
    "keybindings": [
      {
        "command": "vscode-barretta.init",
        "key": "ctrl+alt+n"
      },
      {
        "command": "vscode-barretta.push",
        "key": "ctrl+alt+i"
      },
      {
        "command": "vscode-barretta.pull",
        "key": "ctrl+alt+e"
      },
      {
        "command": "vscode-barretta.open",
        "key": "ctrl+alt+o"
      }
    ],
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "vscode-barretta.launcher",
          "name": "%view.launcher.name%"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "yarn package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "yarn compile-tests && yarn compile",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format --check .",
    "test": "node ./out/test/runTest.js"
    },
  "devDependencies": {
    "@biomejs/biome": "2.0.5",
    "@types/encoding-japanese": "^2.0.1",
    "@types/glob": "^8.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.68.0",
    "@vscode/test-electron": "^2.1.3",
    "glob": "^8.0.3",
    "mocha": "^10.0.0",
    "ts-loader": "^9.3.0",
    "typescript": "^4.7.2",
    "webpack": "^5.72.1",
    "webpack-cli": "^5.0.0"
  },
  "dependencies": {
    "@vscode/l10n": "^0.0.18",
    "child-process": "^1.0.2",
    "encoding-japanese": "^2.0.0",
    "iconv-lite": "^0.6.3",
    "shx": "^0.4.0",
    "util": "^0.12.4"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}